{
  "name": "harubble",
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "type": "module",
  "description": "Cross-platform lossless music player and downloader built with Rust + Tauri 2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "i18n:generate": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy globalVariable baseLocale --silent",
    "format": "prettier --write \"**/*.{js,mjs,cjs,ts,svelte,md}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,ts,svelte,md}\"",
    "lint": "bun run lint:eslint && bun run lint:rustfmt",
    "lint:eslint": "eslint .",
    "lint:rustfmt": "cargo fmt --all --check",
    "check": "bun run format:check && bun run lint:eslint && bun run lint:rustfmt && bun run check:types && bun run check:svelte && bun run check:build && bun run check:cargo",
    "check:types": "bun run i18n:generate && tsc --noEmit",
    "check:svelte": "bun run i18n:generate && bunx svelte-check",
    "check:build": "vite build",
    "check:cargo": "cargo check --workspace",
    "sort:tags": "bun scripts/sort-tag-registry.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "idb-keyval": "^6.2.2",
    "overlayscrollbars": "^2.15.1",
    "overlayscrollbars-svelte": "^0.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.16.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "bits-ui": "^2.17.3",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "mode-watcher": "^1.1.0",
    "opencc-js": "^1.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.3.1",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.5"
  }
}
